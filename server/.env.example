# ── Database ────────────────────────────────────────────────────────────────
# Supabase: use the pooled connection string (port 6543, pgbouncer) here…
DATABASE_URL="postgresql://doremi:doremi_dev@localhost:5432/doremi?schema=public"
# …and the direct connection (port 5432) for migrations. Locally: same URL.
DIRECT_URL="postgresql://doremi:doremi_dev@localhost:5432/doremi?schema=public"

# ── API server ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Auth (Supabase) ─────────────────────────────────────────────────────────
# Supabase project → Settings → API → JWT Secret. The API only VERIFIES tokens;
# issuing them is Supabase Auth's job (or /api/dev/login in development).
# Production refuses placeholders or values shorter than 32 chars.
SUPABASE_JWT_SECRET=dev_supabase_jwt_secret_change_me

# ── Music source (Invidious-compatible) ─────────────────────────────────────
# Comma-separated instance base URLs, tried in order (failover).
# Example production value: https://inv.example.org,https://inv2.example.org
YT_INSTANCES=http://localhost:4000/mock/invidious

# ── Development toggles (must be OFF in production — enforced at startup) ───
# Mounts a local mock Invidious instance at /mock/invidious (offline dev/CI).
MOCK_YT=1
# Enables POST /api/dev/login, which mints Supabase-shaped JWTs without Supabase.
DEV_AUTH=1
